# LLM API Configuration (OpenAI SDK compatible)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-3.1-flash-lite-preview

# Simulation config
OASIS_DEFAULT_MAX_ROUNDS=3

# ===== Cloudflare Browser Rendering (Web Crawling) =====
# Account ID: https://dash.cloudflare.com/ → ID in URL after /accounts/
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
# API Token: create with "Browser Rendering - Edit" permission
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ===== Zep Graph Memory Configuration =====
# Free tier: https://app.getzep.com/
ZEP_API_KEY=your-zep-api-key-here

# Graphiti (local knowledge graph — Kuzu embedded, no external DB needed)
GRAPHITI_DB_PATH=./data/graphiti

# ===== Boost LLM (optional) =====
# LLM_BOOST_API_KEY=your-api-key-here
# LLM_BOOST_BASE_URL=your-base-url-here
# LLM_BOOST_MODEL_NAME=your-model-name-here
