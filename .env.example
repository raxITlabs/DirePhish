# LLM API Configuration (OpenAI SDK compatible)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-3.1-flash-lite-preview
# Pro model for report generation (higher quality, same API)
# LLM_PRO_MODEL=gemini-3.1-pro-preview

# Simulation config
OASIS_DEFAULT_MAX_ROUNDS=3

# ===== Cloudflare Browser Rendering (Web Crawling) =====
# Account ID: https://dash.cloudflare.com/ → ID in URL after /accounts/
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
# API Token: create with "Browser Rendering - Edit" permission
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# ===== Google Cloud / Firestore Vector Search =====
# GCP project with Firestore Native mode enabled
# Auth: run `gcloud auth application-default login` locally
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# FIRESTORE_DATABASE=(default)
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIMENSIONS=768

# Monte Carlo simulation
# MONTE_CARLO_MAX_WORKERS=3
# GEMINI_RPM_LIMIT=60

# ===== Zep Graph Memory (deprecated — replaced by Firestore) =====
ZEP_API_KEY=your-zep-api-key-here

# Graphiti (deprecated — replaced by Firestore)
GRAPHITI_DB_PATH=./data/graphiti


# Workflow SDK — see frontend/.env for WORKFLOW_LOCAL_DATA_DIR

# Docker Compose: published host ports (defaults 3000 / 5001 if unset).
# If you see "port is already allocated", pick free ports here, then open
# http://localhost:${HOST_PORT_FRONTEND} in the browser.
# HOST_PORT_FRONTEND=3010
# HOST_PORT_BACKEND=5010

# Optional: backend URL for Next.js server-side calls. Docker Compose sets this to
# http://127.0.0.1:5001 automatically. For local `./start.sh`, default is fine.
# FLASK_API_URL=http://127.0.0.1:5001

# ===== Boost LLM (optional) =====
# LLM_BOOST_API_KEY=your-api-key-here
# LLM_BOOST_BASE_URL=your-base-url-here
# LLM_BOOST_MODEL_NAME=your-model-name-here
